---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { comparisons } from '../../data/site';
---

<BaseLayout
  title="Best AI Tools"
  description="High-intent comparison pages for the best AI tools for coding, SEO, startups, image generation, and agents."
  canonicalPath="/best/"
>
  <section class="hero">
    <div class="eyebrow">Comparisons</div>
    <h1>Best AI tools for the jobs people actually search for.</h1>
    <p style="margin-top:1rem; max-width:70ch;">Use comparison pages to capture keyword intent and guide visitors toward a practical shortlist.</p>
  </section>

  <section class="section">
    <div class="cards">
      {comparisons.map((comparison) => (
        <a class="card" href={`/best/${comparison.slug}/`}>
          <h3>{comparison.title}</h3>
          <p>{comparison.description}</p>
          <div class="card-meta">{comparison.toolSlugs.length} tools compared</div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
